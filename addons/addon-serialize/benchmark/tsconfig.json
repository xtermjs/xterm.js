{
  "compilerOptions": {
    "lib": [
      "dom",
      "es2021"
    ],
    "rootDir": "..",
    "outDir": "../out-benchmark",
    "types": ["../../../node_modules/@types/node"],
    "moduleResolution": "nodenext",
    "strict": false,
    "target": "es2021",
    "module": "nodenext",
    "paths": {
      "common/*": [
        "../../../src/primitives/*",
        "../../../src/runtime/*",
      ],
      "target-browser/*": ["../../../src/target-browser/*"],
      "SerializeAddon": ["../src/SerializeAddon"],
      "@xterm/addon-serialize": [
        "../typings/addon-serialize.d.ts"
      ]
    }
  },
  "include": ["../**/*", "../../../typings/xterm.d.ts"],
  "exclude": ["../../../**/*test.ts", "../../**/*api.ts"],
  "references": [
    { "path": "../../../src" },
    { "path": "../../../src/target-browser" }
  ]
}
