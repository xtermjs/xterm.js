{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "sourceMap": true,
    "outDir": "../out",
    "rootDir": ".",
    "strict": true,
    "noUnusedLocals": true,
    "preserveWatchOutput": true,
    "types": [
      "../../../node_modules/@types/mocha"
    ],
    "paths": {
      "target-browser/*": [ "../../../src/target-browser/*" ],
      "common/*": [
        "../../../src/primitives/*",
        "../../../src/runtime/*",
      ],
      "@xterm/addon-image": [ "../typings/addon-image.d.ts" ],
      "*": [ "./*" ]
    }
  },
  "include": [
    "./**/*",
    "../../../typings/xterm.d.ts"
  ],
  "references": [
    { "path": "../../../src/target-browser" },
    { "path": "../../../src" }
  ]
}
