{
  "compilerOptions": {
    "lib": ["dom", "es6"],
    "rootDir": "..",
    "outDir": "../out-benchmark",
    "types": ["../../../node_modules/@types/node"],
    "moduleResolution": "nodenext",
    "strict": false,
    "target": "es2015",
    "module": "nodenext",
    "paths": {
      "common/*": [
        "../../../src/primitives/*",
        "../../../src/runtime/*",
      ],
      "target-browser/*": ["../../../src/target-browser/*"],
      "UnicodeGraphemeProvider": ["../src/UnicodeGraphemeProvider"],
      "@xterm/addon-unicode-graphemes": [
        "../typings/addon-unicode-graphemes.d.ts"
      ]
    }
  },
  "include": ["../**/*", "../../../typings/xterm.d.ts"],
  "exclude": ["../../../**/*test.ts", "../../**/*api.ts"],
  "references": [
    { "path": "../../../src" },
    { "path": "../../../src/target-browser" }
  ]
}
