{
  "compilerOptions": {
    "lib": [
      "dom",
      "es2021",
    ],
    "outDir": "../../out-test/benchmark",
    "rootDir": "../..",
    "types": [
      "../../node_modules/@types/node"
    ],
    "moduleResolution": "nodenext",
    "strict": false,
    "target": "es2021",
    "module": "nodenext",
    "paths": {
      "common/*": [
        "../../src/common/primitives/*",
        "../../src/common/runtime/*",
        "../../src/common/*"
      ],
      "target-browser/*": [ "../../src/target-browser/*" ],
      "Terminal": ["../../src/Terminal"]
    },
  },
  "include": [
    "./**/*",
    "../../typings/xterm.d.ts"
  ],
  "exclude": [
    "../../**/*test.ts"
  ],
  "references": [
    { "path": "../../src/common" },
    { "path": "../../src/target-browser" },
  ]
}
