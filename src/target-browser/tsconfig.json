{
  "extends": "../tsconfig-library-base",
  "compilerOptions": {
    "lib": [
      "dom",
      "es2021"
    ],
    "outDir": "../../out",
    "types": [
      "../../node_modules/@types/mocha"
    ],
    "skipLibCheck": true,
    "paths": {
      "common/buffer/*": ["../common/primitives/buffer/*"],
      "common/data/*": ["../common/primitives/data/*"],
      "common/input/*": ["../common/primitives/input/*"],
      "common/parser/*": ["../common/primitives/parser/*"],
      "common/services/*": ["../common/runtime/services/*"],
      "common/public/*": ["../common/runtime/public/*"],
      "common/Types": ["../common/runtime/Types"],
      "common/*": ["../common/primitives/*", "../common/runtime/*"],
      "*": [ "./../*" ]
    }
  },
  "include": [
    "./**/*",
    "../../typings/xterm.d.ts"
  ],
  "exclude": [
    "**/*.test.ts"
  ],
  "references": [
    { "path": "../common" }
  ]
}
