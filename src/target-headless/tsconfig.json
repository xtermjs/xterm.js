{
  "extends": "../tsconfig-library-base",
  "compilerOptions": {
    "lib": [
      "es2015",
      "es2016.Array.Include",
      "es2021.weakref"
    ],
    "outDir": "../../out",
    "types": [
      "../../node_modules/@types/mocha",
      "../../node_modules/@types/node"
    ],
    "paths": {
      "common/buffer/*": ["../primitives/buffer/*"],
      "common/data/*": ["../primitives/data/*"],
      "common/input/*": ["../primitives/input/*"],
      "common/parser/*": ["../primitives/parser/*"],
      "common/services/*": ["../runtime/services/*"],
      "common/public/*": ["../runtime/public/*"],
      "common/Types": ["../runtime/Types"],
      "common/*": ["../primitives/*", "../runtime/*"],
      "*": [ "./../*" ]
    }
  },
  "include": [
    "./**/*",
    "../../typings/xterm.d.ts", // common/Types.d.ts imports from '@xterm/xterm'
    "../../typings/xterm-headless.d.ts"
  ],
  "exclude": [
    "**/*.test.ts"
  ],
  "references": [
    { "path": ".." }
  ]
}
