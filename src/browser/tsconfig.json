{
  "extends": "../tsconfig-library-base",
  "compilerOptions": {
    "lib": [
      "dom",
      "es2021"
    ],
    "outDir": "../../out",
    "types": [
      "../../node_modules/@types/mocha"
    ],
    "skipLibCheck": true,
    "paths": {
      "common/*": [
        "./../common/primitives/*",
        "./../common/runtime/*",
        "./../common/*"
      ],
      "*": [ "./../*" ]
    }
  },
  "include": [
    "./**/*",
    "../../typings/xterm.d.ts"
  ],
  "references": [
    { "path": "../common" }
  ]
}
