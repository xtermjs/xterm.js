{
  "extends": "../tsconfig-library-base",
  "compilerOptions": {
    "lib": [
      "es2015",
      "es2016.Array.Include",
      "es2019.string",
      "es2021.weakref",
      "dom"
    ],
    "outDir": "../../out/common",
    "rootDir": ".",
    "types": [
      "../../node_modules/@types/mocha"
    ],
    "paths": {
      "common/base/*": ["./base/*"],
      "common/encoding/*": ["./encoding/*"],
      "common/data/*": ["./data/*"],
      "common/buffer/*": ["./buffer/*"],
      "common/parser/*": ["./parser/*"],
      "common/input/*": ["./input/*"],
      "common/services/*": ["./services/*"],
      "common/terminal/*": ["./terminal/*"],
      "common/public/*": ["./public/*"],
      "common/*": ["./*"],
      "*": ["../*"]
    }
  },
  "include": [
    "./base/**/*",
    "./encoding/**/*",
    "./data/**/*",
    "./buffer/**/*",
    "./parser/**/*",
    "./input/**/*",
    "./services/**/*",
    "./terminal/**/*",
    "./public/**/*",
    "../../typings/xterm.d.ts"
  ]
}
