{
  "extends": "../../tsconfig-library-base",
  "compilerOptions": {
    "lib": [
      "es2015",
      "es2016.Array.Include",
      "es2019.string",
      "es2021.weakref",
      "dom"
    ],
    "types": [
      "../../../node_modules/@types/mocha"
    ],
    "paths": {
      "@xterm/xterm": ["../../../typings/xterm.d.ts"],
      "common/base/*": ["../base/*"],
      "common/buffer/*": ["../buffer/*"],
      "common/parser/*": ["../parser/*"],
      "common/input/*": ["./*"],
      "common/services/*": ["../services/*"],
      "common/terminal/*": ["../terminal/*"],
      "common/public/*": ["../public/*"],
      "common/*": ["../*"],
      "*": ["../../*"]
    },
    "outDir": "../../../out/common/input",
    "rootDir": "."
  },
  "include": [
    "./**/*"
  ],
  "exclude": [
    "**/*.test.ts"
  ],
  "references": [
    { "path": "../base" },
    { "path": "../buffer" },
    { "path": "../parser" }
  ]
}
